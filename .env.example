# Site URL used for checkout redirects (use your production URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Square checkout configuration
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id

# Google Sheets product source
# Spreadsheet ID from:
# https://docs.google.com/spreadsheets/d/<THIS_PART_IS_THE_ID>/edit
GOOGLE_SHEETS_PRODUCT_ID=1t4fygKrcP2AH4HL1-Y9APKvOx_Oy7nqbOoml_4M-H4U

# Google OAuth credentials (for an account that can edit the sheet)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
